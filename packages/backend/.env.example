# ============================================================
# Agent Player v1.3.0 - Backend Environment Variables
# ============================================================
# Copy this file to .env and customize for your environment
# ============================================================

# ─── SERVER CONFIGURATION ─────────────────────────────────────
# Backend server port and host
# Change if these ports conflict with your other services
PORT=41522
HOST=0.0.0.0
NODE_ENV=development

# ─── FRONTEND URL ─────────────────────────────────────────────
# Frontend application URL (used for CORS, OAuth redirects, embed URLs)
# IMPORTANT: Update this when deploying to production
NEXT_PUBLIC_APP_URL="http://localhost:41521"

# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL="file:./.data/agent-player.db"
DATABASE_PATH=./.data/agent-player.db

# ─── ENCRYPTION ───────────────────────────────────────────────
# Auto-generated on first run
ENCRYPTION_KEY=
MASTER_ENCRYPTION_KEY=

# ─── AI PROVIDERS ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── LOCAL AI (Ollama) ────────────────────────────────────────
OLLAMA_URL="http://localhost:11434"
LOCAL_MODEL_API_URL="http://localhost:11434/v1"
LOCAL_MODEL_NAME="qwen2.5:7b"
LOCAL_MODEL_API_KEY="sk-dummy"

# ─── AUTH ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── OPTIONAL CHANNELS ────────────────────────────────────────
WHATSAPP_SESSION_PATH=./.data/whatsapp-session
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
