{
  "id": "slack",
  "name": "Slack",
  "description": "Slack messaging channel for Agent Player",
  "version": "1.0.0",
  "author": "Agent Player Team",
  "channels": ["slack"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["bot_token", "signing_secret"],
    "properties": {
      "bot_token": {
        "type": "string",
        "description": "Slack Bot User OAuth Token (xoxb-...)"
      },
      "signing_secret": {
        "type": "string",
        "description": "Slack Signing Secret"
      },
      "app_token": {
        "type": "string",
        "description": "Slack App Token for Socket Mode (xapp-...)"
      },
      "allowed_channels": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of allowed channel IDs"
      }
    }
  }
}
