{
  "id": "team",
  "name": "Team Management",
  "version": "1.0.0",
  "description": "Team collaboration with members, roles, and invitations",
  "author": "Agent Player Team",
  "type": "app",
  "main": "src/index.js",
  "permissions": ["database", "routes"],

  "capabilities": {
    "database": true,
    "routes": true,
    "cron": false,
    "tools": false,
    "frontend": true
  },

  "routes": [
    {
      "method": "GET",
      "path": "/api/team",
      "description": "Get user teams"
    },
    {
      "method": "POST",
      "path": "/api/team",
      "description": "Create team"
    },
    {
      "method": "GET",
      "path": "/api/team/:id",
      "description": "Get team details"
    },
    {
      "method": "PUT",
      "path": "/api/team/:id",
      "description": "Update team"
    },
    {
      "method": "DELETE",
      "path": "/api/team/:id",
      "description": "Delete team"
    },
    {
      "method": "GET",
      "path": "/api/team/:id/members",
      "description": "Get team members"
    },
    {
      "method": "DELETE",
      "path": "/api/team/:id/members/:userId",
      "description": "Remove team member"
    },
    {
      "method": "PUT",
      "path": "/api/team/:id/members/:userId/role",
      "description": "Update member role"
    },
    {
      "method": "POST",
      "path": "/api/team/:id/invite",
      "description": "Send team invitation"
    },
    {
      "method": "GET",
      "path": "/api/team/invitations",
      "description": "Get pending invitations"
    },
    {
      "method": "GET",
      "path": "/api/team/:id/invitations",
      "description": "Get team invitations"
    },
    {
      "method": "POST",
      "path": "/api/team/invitations/:token/accept",
      "description": "Accept invitation"
    },
    {
      "method": "DELETE",
      "path": "/api/team/invitations/:id",
      "description": "Cancel/reject invitation"
    }
  ],

  "migrations": [
    "migrations/001_team_tables.sql"
  ],

  "frontendRoutes": [
    {
      "path": "/dashboard/ext/team",
      "name": "Team",
      "icon": "Users",
      "position": "main"
    }
  ]
}
