{
  "id": "discord",
  "name": "Discord",
  "description": "Discord messaging channel for Agent Player",
  "version": "1.0.0",
  "author": "Agent Player Team",
  "channels": ["discord"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["bot_token"],
    "properties": {
      "bot_token": {
        "type": "string",
        "description": "Discord Bot Token"
      },
      "client_id": {
        "type": "string",
        "description": "Discord Application Client ID"
      },
      "guild_id": {
        "type": "string",
        "description": "Server ID (for server-specific bots)"
      },
      "allowed_channels": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of allowed channel IDs"
      }
    }
  }
}
