{
  "id": "telegram",
  "name": "Telegram",
  "description": "Telegram messaging channel for Agent Player",
  "version": "1.0.0",
  "author": "Agent Player Team",
  "channels": ["telegram"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["bot_token"],
    "properties": {
      "bot_token": {
        "type": "string",
        "description": "Telegram Bot Token from @BotFather"
      },
      "webhook_url": {
        "type": "string",
        "description": "Webhook URL for receiving updates"
      },
      "allowed_users": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of allowed Telegram user IDs"
      }
    }
  }
}
