{
  "id": "email-client",
  "name": "Email Client",
  "version": "1.0.0",
  "description": "Professional email client with multi-account support, Gmail/Outlook OAuth, IMAP/SMTP sync, and full-text search",
  "author": "Agent Player",
  "capabilities": {
    "database": true,
    "cron": true,
    "tools": false,
    "api": true,
    "frontend": true
  },
  "settings": {
    "type": "ui-web4",
    "spec": {
      "type": "form",
      "components": [
        {
          "type": "heading",
          "text": "Email Client Settings",
          "level": 2
        },
        {
          "type": "text",
          "content": "Configure email account sync intervals and storage settings."
        },
        {
          "type": "input",
          "id": "defaultSyncInterval",
          "label": "Default Sync Interval (minutes)",
          "placeholder": "5",
          "defaultValue": "5"
        },
        {
          "type": "select",
          "id": "defaultProvider",
          "label": "Default Email Provider",
          "options": [
            {"label": "Gmail", "value": "gmail"},
            {"label": "Outlook", "value": "outlook"},
            {"label": "IMAP/SMTP", "value": "imap"}
          ],
          "defaultValue": "gmail"
        },
        {
          "type": "checkbox",
          "id": "autoDownloadAttachments",
          "label": "Auto-download attachments",
          "defaultValue": false
        },
        {
          "type": "checkbox",
          "id": "enableFullTextSearch",
          "label": "Enable full-text search (FTS5)",
          "defaultValue": true
        }
      ]
    }
  }
}
