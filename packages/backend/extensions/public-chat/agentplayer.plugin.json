{
  "id": "public-chat",
  "name": "Public Chat Rooms",
  "version": "1.0.0",
  "description": "Multi-user chat rooms with AI agents and customizable avatars",
  "author": "Agent Player Team",
  "type": "app",
  "main": "src/index.js",
  "permissions": ["database", "routes"],

  "capabilities": {
    "database": true,
    "routes": true,
    "cron": false,
    "tools": false,
    "frontend": true
  },

  "routes": [
    {
      "method": "GET",
      "path": "/api/public-chat/rooms",
      "description": "Get all public chat rooms"
    },
    {
      "method": "POST",
      "path": "/api/public-chat/rooms",
      "description": "Create public chat room"
    },
    {
      "method": "GET",
      "path": "/api/public-chat/rooms/:roomId",
      "description": "Get room details"
    },
    {
      "method": "PUT",
      "path": "/api/public-chat/rooms/:roomId",
      "description": "Update room settings"
    },
    {
      "method": "DELETE",
      "path": "/api/public-chat/rooms/:roomId",
      "description": "Delete room"
    },
    {
      "method": "GET",
      "path": "/api/public-chat/rooms/:roomId/messages",
      "description": "Get room messages"
    },
    {
      "method": "POST",
      "path": "/api/public-chat/rooms/:roomId/messages",
      "description": "Send message (SSE stream)"
    },
    {
      "method": "GET",
      "path": "/api/public-chat/rooms/:roomId/participants",
      "description": "Get active participants"
    },
    {
      "method": "POST",
      "path": "/api/public-chat/rooms/:roomId/join",
      "description": "Join room"
    }
  ],

  "migrations": [
    "migrations/001_public_chat_tables.sql"
  ],

  "frontendRoutes": [
    {
      "path": "/dashboard/ext/public-chat",
      "name": "Public Chat",
      "icon": "MessagesSquare",
      "position": "main"
    }
  ]
}
