## NEW FEATURE DETAILS - LOCAL AI ENDPOINT SUGGESTIONS

### **Feature Overview:**
```typescript
interface EndpointSuggestion {
  serverName: string;        // e.g., "Ollama"
  defaultHost: string;       // e.g., "localhost"
  defaultPort: string;       // e.g., "11434"
  endpoint: string;          // e.g., "/v1/chat/completions"
  difficulty: 'easy' | 'medium' | 'hard';
  isRecommended: boolean;    // Based on model compatibility
  compatibilityScore: number; // 0-1 based on model matching
  status: 'working' | 'available' | 'unknown';
}
```

### **Smart Matching Algorithm:**
```typescript
// The system intelligently matches AI models to appropriate servers
const getRecommendedServers = (modelName: string) => {
  // Ollama models → Suggest Ollama server
  if (modelName.includes('llama') || modelName.includes('mistral')) {
    return [ollama, lmstudio, textgen_webui];
  }
  
  // Code models → Suggest coding-optimized servers
  if (modelName.includes('code')) {
    return [ollama, lmstudio, vllm];
  }
  
  // Default suggestions for any model
  return [ollama, lmstudio, localai];
};
```

