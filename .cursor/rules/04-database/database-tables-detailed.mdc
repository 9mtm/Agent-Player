## 🔥 **NEW DOMAIN 12: CUSTOM FIELD BUILDER (4 tables) - PLANNED**

### **38. custom_fields** - Field definitions and configuration
```sql
CREATE TABLE custom_fields (
    id INTEGER PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    label VARCHAR(200) NOT NULL,
    field_type VARCHAR(50) NOT NULL, -- 'text', 'number', 'select', 'checkbox'
    description TEXT,
    placeholder VARCHAR(255),
    default_value TEXT,
    options TEXT, -- JSON for select/radio options
    validation_rules TEXT, -- JSON validation config
    is_required BOOLEAN DEFAULT FALSE,
    position INTEGER DEFAULT 0,
    group_id INTEGER,
    created_by INTEGER NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (group_id) REFERENCES custom_field_groups(id),
    FOREIGN KEY (created_by) REFERENCES users(id)
);
```

### **39. custom_field_groups** - Field grouping and organization
```sql
CREATE TABLE custom_field_groups (
    id INTEGER PRIMARY KEY,
    name VARCHAR(200) NOT NULL,
    description TEXT,
    location VARCHAR(100) NOT NULL, -- 'agent_form', 'task_form', 'profile'
    entity_type VARCHAR(50), -- 'agent', 'task', 'user'
    display_rules TEXT, -- JSON conditions for showing
    position INTEGER DEFAULT 0,
    is_active BOOLEAN DEFAULT TRUE,
    created_by INTEGER NOT NULL,
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (created_by) REFERENCES users(id)
);
```

### **40. custom_field_values** - User-entered field values
```sql
CREATE TABLE custom_field_values (
    id INTEGER PRIMARY KEY,
    field_id INTEGER NOT NULL,
    entity_type VARCHAR(50) NOT NULL, -- 'agent', 'task', 'user'
    entity_id INTEGER NOT NULL,
    value TEXT, -- Stored as JSON for complex values
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (field_id) REFERENCES custom_fields(id),
    UNIQUE(field_id, entity_type, entity_id)
);
```

### **41. field_templates** - Reusable field configurations
```sql
CREATE TABLE field_templates (
    id INTEGER PRIMARY KEY,
    name VARCHAR(200) NOT NULL,
    description TEXT,
    category VARCHAR(100), -- 'agent', 'task', 'general'
    fields_config TEXT NOT NULL, -- JSON field definitions
    preview_image VARCHAR(255),
    is_public BOOLEAN DEFAULT FALSE,
    usage_count INTEGER DEFAULT 0,
    created_by INTEGER NOT NULL,
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (created_by) REFERENCES users(id)
);
```

