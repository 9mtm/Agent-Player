## 🗄️ **NEW DOMAIN 12: CUSTOM FIELD BUILDER (4 tables)**

### **Table 38: custom_fields** - Field definitions and configuration
```sql
CREATE TABLE custom_fields (
    id INTEGER PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    label VARCHAR(200) NOT NULL,
    field_type VARCHAR(50) NOT NULL, -- 'text', 'number', 'select', 'checkbox', 'date', 'file'
    description TEXT,
    placeholder VARCHAR(255),
    default_value TEXT,
    options TEXT, -- JSON for select/radio options: {"options": [{"label": "Option 1", "value": "opt1"}]}
    validation_rules TEXT, -- JSON validation config: {"required": true, "minLength": 3, "maxLength": 100}
    is_required BOOLEAN DEFAULT FALSE,
    position INTEGER DEFAULT 0,
    group_id INTEGER,
    created_by INTEGER NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (group_id) REFERENCES custom_field_groups(id),
    FOREIGN KEY (created_by) REFERENCES users(id)
);

-- Indexes for performance
CREATE INDEX idx_custom_fields_type ON custom_fields(field_type);
CREATE INDEX idx_custom_fields_group ON custom_fields(group_id);
CREATE INDEX idx_custom_fields_active ON custom_fields(is_active);
```

### **Table 39: custom_field_groups** - Field grouping and organization
```sql
CREATE TABLE custom_field_groups (
    id INTEGER PRIMARY KEY,
    name VARCHAR(200) NOT NULL,
    description TEXT,
    location VARCHAR(100) NOT NULL, -- 'agent_form', 'task_form', 'profile', 'training_form'
    entity_type VARCHAR(50), -- 'agent', 'task', 'user', 'training'
    display_rules TEXT, -- JSON conditions: {"show_when": {"agent_type": "conversational"}}
    position INTEGER DEFAULT 0,
    is_active BOOLEAN DEFAULT TRUE,
    created_by INTEGER NOT NULL,
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (created_by) REFERENCES users(id)
);

-- Indexes for performance
CREATE INDEX idx_custom_field_groups_location ON custom_field_groups(location);
CREATE INDEX idx_custom_field_groups_entity ON custom_field_groups(entity_type);
CREATE INDEX idx_custom_field_groups_active ON custom_field_groups(is_active);
```

### **Table 40: custom_field_values** - User-entered field values
```sql
CREATE TABLE custom_field_values (
    id INTEGER PRIMARY KEY,
    field_id INTEGER NOT NULL,
    entity_type VARCHAR(50) NOT NULL, -- 'agent', 'task', 'user'
    entity_id INTEGER NOT NULL,
    value TEXT, -- Stored as JSON for complex values: {"text": "value"} or {"array": ["val1", "val2"]}
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (field_id) REFERENCES custom_fields(id),
    UNIQUE(field_id, entity_type, entity_id)
);

-- Indexes for performance
CREATE INDEX idx_custom_field_values_entity ON custom_field_values(entity_type, entity_id);
CREATE INDEX idx_custom_field_values_field ON custom_field_values(field_id);
```

### **Table 41: field_templates** - Reusable field configurations
```sql
CREATE TABLE field_templates (
    id INTEGER PRIMARY KEY,
    name VARCHAR(200) NOT NULL,
    description TEXT,
    category VARCHAR(100), -- 'agent', 'task', 'general', 'ecommerce', 'blog'
    fields_config TEXT NOT NULL, -- JSON field definitions array
    preview_image VARCHAR(255),
    is_public BOOLEAN DEFAULT FALSE,
    usage_count INTEGER DEFAULT 0,
    created_by INTEGER NOT NULL,
    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,
    FOREIGN KEY (created_by) REFERENCES users(id)
);

-- Indexes for performance
CREATE INDEX idx_field_templates_category ON field_templates(category);
CREATE INDEX idx_field_templates_public ON field_templates(is_public);
CREATE INDEX idx_field_templates_usage ON field_templates(usage_count DESC);
```

