<?xml version="1.0" encoding="UTF-8"?>
<service>
    <id>AgentPlayerFrontend</id>
    <name>Agent Player Frontend</name>
    <description>Agent Player Frontend Service - Next.js Web Application</description>

    <executable>{{INSTALL_DIR}}\runtime\node\node.exe</executable>
    <arguments>packages\frontend\server.js</arguments>
    <workingdirectory>{{INSTALL_DIR}}\app</workingdirectory>

    <env name="NODE_ENV" value="production"/>
    <env name="PORT" value="{{FRONTEND_PORT}}"/>
    <env name="NEXT_PUBLIC_API_URL" value="http://localhost:{{BACKEND_PORT}}"/>
    <env name="PATH" value="{{INSTALL_DIR}}\runtime\node;%PATH%"/>

    <depend>AgentPlayerBackend</depend>

    <startmode>Automatic</startmode>
    <delayedAutoStart>true</delayedAutoStart>

    <onfailure action="restart" delay="10 sec"/>
    <onfailure action="restart" delay="30 sec"/>
    <onfailure action="restart" delay="60 sec"/>

    <resetfailure>1 hour</resetfailure>

    <logmode>rotate</logmode>
    <logpath>{{INSTALL_DIR}}\logs</logpath>

    <priority>Normal</priority>

    <stoptimeout>30 sec</stoptimeout>
</service>
