<?xml version="1.0" encoding="UTF-8"?>
<service>
    <id>AgentPlayerBackend</id>
    <name>Agent Player Backend</name>
    <description>Agent Player Backend Service - Fastify API Server</description>

    <executable>{{INSTALL_DIR}}\runtime\node\node.exe</executable>
    <arguments>dist\api\server.js</arguments>
    <workingdirectory>{{INSTALL_DIR}}\app\packages\backend</workingdirectory>

    <env name="NODE_ENV" value="production"/>
    <env name="PORT" value="{{BACKEND_PORT}}"/>
    <env name="PATH" value="{{INSTALL_DIR}}\runtime\node;{{INSTALL_DIR}}\runtime\python;%PATH%"/>

    <startmode>Automatic</startmode>
    <delayedAutoStart>true</delayedAutoStart>

    <onfailure action="restart" delay="10 sec"/>
    <onfailure action="restart" delay="30 sec"/>
    <onfailure action="restart" delay="60 sec"/>

    <resetfailure>1 hour</resetfailure>

    <logmode>rotate</logmode>
    <logpath>{{INSTALL_DIR}}\logs</logpath>

    <priority>Normal</priority>

    <stoptimeout>30 sec</stoptimeout>
</service>
