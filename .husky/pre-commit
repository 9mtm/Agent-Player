#!/usr/bin/env sh
# SECURITY: Pre-commit hook to prevent committing secrets and sensitive data (L-06)
# This hook runs automatically before each git commit

. "$(dirname -- "$0")/_/husky.sh"

echo "🔒 Running pre-commit security checks..."

# Check for common secret patterns
FORBIDDEN_PATTERNS=(
  "API_KEY"
  "SECRET_KEY"
  "PASSWORD"
  "PRIVATE_KEY"
  "AWS_SECRET"
  "DATABASE_URL"
  "JWT_SECRET"
  "ANTHROPIC_API_KEY"
  "OPENAI_API_KEY"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
  for PATTERN in "${FORBIDDEN_PATTERNS[@]}"; do
    # Check if file contains the pattern (case-insensitive)
    if git diff --cached "$FILE" | grep -iE "$PATTERN\s*=\s*['\"]?[a-zA-Z0-9_-]{10,}" > /dev/null; then
      echo "❌ ERROR: Possible secret detected in $FILE"
      echo "   Pattern matched: $PATTERN"
      echo ""
      echo "   If this is a false positive, you can:"
      echo "   1. Remove the actual secret and use environment variables"
      echo "   2. Add the file to .gitignore"
      echo "   3. Skip this hook with: git commit --no-verify (NOT RECOMMENDED)"
      echo ""
      exit 1
    fi
  done
done

# Check for .env files being committed
if echo "$STAGED_FILES" | grep -E "\.env$|\.env\.local$" > /dev/null; then
  echo "❌ ERROR: .env file detected in commit"
  echo "   .env files should never be committed to version control"
  echo "   Add them to .gitignore instead"
  exit 1
fi

echo "✅ Pre-commit security checks passed"
exit 0
