# ==============================================
# Application Configuration
# ==============================================

# Public URL for the frontend application
NEXT_PUBLIC_APP_URL="http://localhost:41521"

# Public URL for the backend API
NEXT_PUBLIC_BACKEND_URL="http://localhost:41522"

# Public URL for the visualizer service
NEXT_PUBLIC_VISUALIZER_URL="http://localhost:3456"

# Workflow Engine Secret (generate a secure random string for production)
WORKFLOW_SECRET="super-secret-key-change-me"

# ==============================================
# Database Configuration
# ==============================================

# SQLite (Recommended for local development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (Recommended for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
# DB_PASSWORD="password"

# Redis (Optional - locally not required unless using specific features)
# REDIS_URL="redis://localhost:6379"

# ==============================================
# AI & LLM Configuration
# ==============================================

# --- Local LLM (Ollama/LM Studio) ---
# Default provider for local development. Use 'openai-compatible' for Ollama.
LOCAL_MODEL_PROVIDER="openai-compatible"
# Standard Ollama endpoint
LOCAL_MODEL_API_URL="http://localhost:11434/v1"
# The model name to use (ensure you have pulled this model in Ollama)
LOCAL_MODEL_NAME="qwen2.5:latest"
# Dummy key required by some SDKs even for local models
LOCAL_MODEL_API_KEY="sk-dummy"
# Base URL for Ollama service
OLLAMA_URL="http://localhost:11434"

# --- Cloud AI Providers (Optional) ---
# Leave blank if using Local LLM exclusively
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# ==============================================
# Storage Configuration
# ==============================================

# --- Local Storage (Default) ---
STORAGE_PROVIDER="local"

# --- AWS S3 (Production) ---
# STORAGE_PROVIDER="s3"
# S3_BUCKET="my-bucket"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PUBLIC_URL="https://cdn.mysite.com"

# --- Cloudflare R2 ---
# STORAGE_PROVIDER="r2"
# R2_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_PUBLIC_URL="https://..."
